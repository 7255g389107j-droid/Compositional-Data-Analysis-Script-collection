# 2. Add some "zeros" to simulate real-world component mismatch
dummy_data[sample(1:500, 100)] <- 0

# 3. Define groups
dummy_groups <- c(rep("Control", 5), rep("Test", 5))

# 4. Run the Engine
analysis_results <- itagaki_static_engine_v20(dummy_data, dummy_groups)
