# =================================================================
# ITAGAKI-SYSTEM V36.5: ULTIMATE BI-PLOT (Anti-Collision Engine)
# -----------------------------------------------------------------
# Feature: Zig-zag Labelling & Forced Sample ID Display
# =================================================================

# --- 1. DATA PREPARATION ---
pca_res <- results$pca 
var_exp <- (pca_res$sdev^2) / sum(pca_res$sdev^2) * 100
pc1_v <- round(var_exp[1], 1); pc2_v <- round(var_exp[2], 1)

# Variance-Weighted Scaling
scaled_L <- sweep(pca_res$rotation, 2, pca_res$sdev, FUN = "*")
top10_idx <- order(abs(scaled_L[, "PC1"]), decreasing = TRUE)[1:10] # TopX and PCX
L_top <- scaled_L[top10_idx, 1:2]
S <- pca_res$x

# --- 2. [MANUAL TUNING AREA] ---
arrow_scale  <- 0.85  # Length of red arrows
base_dist    <- 1.18  # Base distance from arrow tip
jitter_y_amp <- 0.12  # Vertical jitter (increase if still overlapping)
jitter_x_amp <- 0.08  # Horizontal jitter for dense areas
sample_cex   <- 1.1   # Sample ID size
load_cex     <- 0.75  # Component name size

# --- 3. DYNAMIC SCALING & RANGE ---
mult <- min((max(S[,1])-min(S[,1]))/max(L_top[,1]), (max(S[,2])-min(S[,2]))/max(L_top[,2])) * arrow_scale
x_lim <- range(c(S[,1], L_top[,1]*mult)) * 1.8 # Expanded margin
y_lim <- range(c(S[,2], L_top[,2]*mult)) * 1.8

# --- 4. PLOT INITIALIZATION ---
par(mar = c(5, 6, 5, 5), bg = "#FDFDFD", las = 1)
plot(S[, 1:2], pch = 21, bg = "#BDC3C7", col = "#7F8C8D", cex = 1.8,
     xlab = paste0("PC1 (", pc1_v, "%): Structural Shift"), 
     ylab = paste0("PC2 (", pc2_v, "%): Underlying Trend"),
     main = "ITAGAKI-SYSTEM: Final Biplot (Zero-Overlap)",
     xlim = x_lim, ylim = y_lim)

grid(col = "#ECF0F1", lty = 1)
abline(h = 0, v = 0, lty = 2, col = "#95A5A6")

# --- 5. SAMPLE LABELLING (FORCED) ---
# Display Sample IDs (1, 2, 3, 4...) with bold font
text(S[, 1], S[, 2], labels = rownames(S), pos = 3, offset = 0.8, cex = sample_cex, font = 2, col = "black")

# --- 6. SCALED LOADING VECTORS ---
arrows(0, 0, L_top[, 1] * mult, L_top[, 2] * mult, col = "#E74C3C", lwd = 3, length = 0.15)

# --- 7. ZIG-ZAG ANTI-COLLISION LABELLING ---
# Logic: Alternate offset distances and vertical positions based on index i
for(i in 1:nrow(L_top)) {
  tx <- L_top[i, 1] * mult
  ty <- L_top[i, 2] * mult
  
  # Calculate base radial position
  angle <- atan2(ty, tx)
  deg   <- angle * 180 / pi
  
  # ZIG-ZAG LOGIC: Alternate radial distance to prevent names from clumping
  # Every second label is pushed further out
  dynamic_dist <- ifelse(i %% 2 == 0, base_dist, base_dist + 0.15)
  
  # VERTICAL JITTER: Alternate slight Y-shifts
  y_jit <- ifelse(i %% 3 == 0, jitter_y_amp * diff(y_lim), 
           ifelse(i %% 3 == 1, -jitter_y_amp * diff(y_lim), 0))
  
  # Determine text position index (1:Bottom, 2:Left, 3:Top, 4:Right)
  d_pos <- ifelse(deg > -45 && deg <= 45, 4,
           ifelse(deg > 45 && deg <= 135, 3,
           ifelse(deg > -135 && deg <= -45, 1, 2)))
  
  # Plot Label with dynamic offset
  text(tx * dynamic_dist, ty * dynamic_dist + y_jit, 
       labels = rownames(L_top)[i], pos = d_pos, 
       cex = load_cex, col = "#2C3E50", font = 2, xpd = TRUE)
}

# --- 8. CHRONOLOGICAL TRAJECTORY ---
lines(S[, 1], S[, 2], col = "#3498DB", lty = 3, lwd = 2)

# --- 9. SUMMARY ---
legend("topright", legend = c("Samples", "Top 10 Drivers"), 
       pch = c(21, NA), lty = c(NA, 1), col = c("#7F8C8D", "#E74C3C"), 
       pt.bg = c("#BDC3C7", NA), bty = "n", cex = 0.8)
